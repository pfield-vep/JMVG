__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# Environment / secrets
.env
.env.*
secrets.toml

# Streamlit local config
.streamlit/secrets.toml

# OS files
.DS_Store
Thumbs.db
desktop.ini
